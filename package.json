{
  "name": "catalog-ingestion",
  "version": "1.0.0",
  "description": "CLI tool to crawl commerce sites and ingest products into Product Bus",
  "type": "module",
  "bin": {
    "catalog-ingestion": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
