    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "p-queue": "^8.0.1",
    "playwright": "^1.49.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "mocha": "^11.1.0",
    "sinon": "^19.0.0"
  }
