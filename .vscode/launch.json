{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Crawl — Sitemap",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/bin/cli.js",
      "args": [
        "crawl",
        "--url", "https://www.adobestore.com",
        "--mode", "sitemap",
        "--output", "./output",
        "--concurrency", "3",
        "--delay", "1500",
        "--verbose"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Crawl — Category",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/bin/cli.js",
      "args": [
        "crawl",
        "--url", "https://www.adobestore.com/all",
        "--mode", "category",
        "--output", "./output",
        "--concurrency", "2",
        "--delay", "2000",
        "--verbose"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Crawl — URL List",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/bin/cli.js",
      "args": [
        "crawl",
        "--url", "https://www.adobestore.com",
        "--mode", "urls",
        "--urls-file", "./urls.txt",
        "--output", "./output",
        "--verbose"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Crawl — Resume",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/bin/cli.js",
      "args": [
        "crawl",
        "--url", "https://www.adobestore.com",
        "--mode", "sitemap",
        "--output", "./output",
        "--resume",
        "--verbose"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Crawl — Limited (5 products)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/bin/cli.js",
      "args": [
        "crawl",
        "--url", "https://www.adobestore.com",
        "--mode", "sitemap",
        "--output", "./output",
        "--max-products", "5",
        "--verbose"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Crawl — Visible Browser",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/bin/cli.js",
      "args": [
        "crawl",
        "--url", "https://www.adobestore.com",
        "--mode", "sitemap",
        "--output", "./output",
        "--max-products", "3",
        "--no-headless",
        "--verbose"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Upload — Dry Run",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/bin/cli.js",
      "args": [
        "upload",
        "--input", "./output",
        "--org", "${input:org}",
        "--site", "${input:site}",
        "--dry-run",
        "--verbose"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Upload — Live",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/bin/cli.js",
      "args": [
        "upload",
        "--input", "./output",
        "--org", "${input:org}",
        "--site", "${input:site}",
        "--api-key", "${input:apiKey}",
        "--verbose"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Status",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/bin/cli.js",
      "args": ["status"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "E2E Tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/mocha",
      "args": [
        "test/e2e/adobestore.test.js",
        "--timeout", "180000"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Unit Tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/mocha",
      "args": [
        "--recursive",
        "test/unit/**/*.test.js"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "inputs": [
    {
      "id": "org",
      "type": "promptString",
      "description": "Product Bus organization name"
    },
    {
      "id": "site",
      "type": "promptString",
      "description": "Product Bus site name"
    },
    {
      "id": "apiKey",
      "type": "promptString",
      "description": "Product Bus API key",
      "password": true
    }
  ]
}
